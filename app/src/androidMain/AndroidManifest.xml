<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <queries>
        <intent>
            <action android:name="android.settings.APP_LOCALE_SETTINGS" />
        </intent>

        <intent>
            <action android:name="android.support.customtabs.action.CustomTabsService" />
        </intent>
    </queries>

    <!--
      usesCleartextTraffic: self-hosted sync reaches the user's own server over plain HTTP on the
      LAN / Tailscale (encryption comes from Tailscale/WireGuard or their reverse-proxy TLS, per
      SELF_HOSTED_SYNC.md). Android's OkHttp engine enforces the cleartext policy, so without this
      every "Save & test" and background sync silently fails on Android 9+. Do not remove.
    -->
    <application
        android:name=".app.infrastructure.android.FoodYouApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="${applicationIcon}"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="${applicationRoundIcon}"
        android:supportsRtl="true"
        android:theme="@style/Theme.FoodYou"
        android:usesCleartextTraffic="true"
        tools:targetApi="36">

        <activity
            android:name=".app.infrastructure.android.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".app.infrastructure.android.ShareProductActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.FoodYou"
            android:windowSoftInputMode="adjustResize">

            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>

        </activity>

        <activity
            android:name=".app.infrastructure.android.CrashReportActivity"
            android:exported="false"
            android:label="CrashReportActivity"
            android:theme="@style/Theme.FoodYou" />

        <activity
            android:name=".app.infrastructure.android.DeveloperActivity"
            android:exported="false"
            android:label="DeveloperActivity"
            android:theme="@style/Theme.FoodYou" />

        <receiver
            android:name=".widget.FoodYouWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>

            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/foodyou_widget_info" />
        </receiver>

        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>
    </application>

</manifest>